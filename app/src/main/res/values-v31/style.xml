<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="MovieFlix" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryDark">@color/white</item>
        <item name="colorAccent">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

            <!-- Splash Screen -->
        <item name="android:windowSplashScreenBackground">@color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/movieflixlogo</item> <!-- Logo tengah -->
        <item name="android:windowSplashScreenBrandingImage">@drawable/movieflixlogo</item> <!-- Logo bawah -->
    </style>
</resources>